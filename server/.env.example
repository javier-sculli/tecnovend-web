# ─── Mercado Pago ────────────────────────────────────────────────────────────
# Obtené tu Access Token en https://developers.mercadopago.com
# Sandbox empieza con TEST-  |  Producción con APP_USR-
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000

# URL pública donde MP envía los webhooks IPN.
# En desarrollo local usá ngrok: npx ngrok http 3000
# Copiá la URL https://xxxx.ngrok-free.app  →  + /api/webhooks/mercadopago
MP_WEBHOOK_URL=https://tu-subdominio.ngrok-free.app/api/webhooks/mercadopago

# Secreto HMAC para verificar firmas de webhooks (opcional en dev, obligatorio en prod)
# Tus integraciones → tu app → Webhooks → Clave secreta
MP_WEBHOOK_SECRET=

# ─── Servidor ────────────────────────────────────────────────────────────────
DATABASE_URL=./tecnovend.db
PORT=3000
NODE_ENV=development
